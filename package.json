{
  "name": "commit-lint-gen",
  "version": "1.0.0",
  "description": "A simple git commit generator",
  "bin": {
    "clg": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "rslib build",
    "test": "vitest",
    "lint": "eslint src"
  },
  "keywords": [],
  "author": "Dhodo",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.12.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "commit-lint-gen": "link:",
    "cosmiconfig": "^9.0.2",
    "openai": "^6.46.0",
    "prompts": "^2.4.2",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.23.2",
    "@types/node": "^26.1.1",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}